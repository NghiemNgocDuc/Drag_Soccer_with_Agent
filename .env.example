# Copy this to .env and fill in your values
SECRET_KEY=generate-a-random-secret-here

# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Upstash Redis — https://console.upstash.com
UPSTASH_REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379
